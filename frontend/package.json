{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "api:gen": "./scripts/api-gen.sh",
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tanstack/vue-query": "^5.62.0",
    "@vee-validate/zod": "^4.15.0",
    "openapi-fetch": "^0.13.4",
    "pinia": "^2.2",
    "reka-ui": "^2.9",
    "vee-validate": "^4.15.0",
    "vue": "^3.4.38",
    "vue-router": "^4.6.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@tanstack/vue-query-devtools": "^5.62.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/user-event": "^14",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.1.3",
    "@vitest/ui": "^2.0.5",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^9.28.0",
    "globals": "^15.9.0",
    "happy-dom": "^15.7.4",
    "lint-staged": "^15.2.10",
    "openapi-typescript": "^7.4.4",
    "postcss": "^8.4.45",
    "prettier": "^3.3.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.4.0",
    "vite": "^5.4.6",
    "vitest": "^2.0.5",
    "vue-tsc": "^2.1.6"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix"
    ],
    "*.{ts,vue,css,md,json}": [
      "prettier --write"
    ]
  }
}
